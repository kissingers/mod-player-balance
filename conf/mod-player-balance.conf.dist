[worldserver]

############################################
# ModPlayerBalance 输出调整模块配置文件
############################################

#
#    ModPlayerBalance.Enable
#        描述: 允许角色伤害/治疗效果调整模块.
#        默认:         0 - 禁用
#                     1 - 允许
#
ModPlayerBalance.Enable = 0

#
#    ModPlayerBalance.DebugInfo
#        描述: 开启调试模式,可以看到技能伤害变化提示.
#        默认:         0 - 禁用
#                     1 - 允许
#
ModPlayerBalance.DebugInfo = 0

#
#    ModPlayerBalance.CheckCommand
#        描述: 当前天赋和技能以及装备的伤害加成查询命令.
#        默认:         "" - 空字符串禁用命令
#                     "jc" - 用 jc 作为查询命令,可换成任何合法的字符串
#
ModPlayerBalance.CheckCommand = ""

#
#    ModPlayerBalance.DefaultTalentPoint
#        描述: 每天赋树默认激活调整伤害所需天赋点数
#        默认:         41
#
ModPlayerBalance.DefaultTalentPoint = 41

############################################
# 职业天赋树伤害调整配置
############################################

#
#    ModPlayerBalance.Warrior.Enable
#        描述: 允许调整战士伤害/治疗效果
#        默认:        0 - 禁用
#                     1 - 允许
#    ModPlayerBalance.Warrior.Rate
#        描述: 战士伤害倍率基数,默认1.0,即不调整
#    ModPlayerBalance.Warrior.Talent1/2/3
#        描述: 战士3系天赋树对应的伤害倍率,默认1.0,即不调整
#    ModPlayerBalance.Warrior.Talent1/2/3Point
#        描述: 战士3系天赋树伤害倍率激活所需点数,默认41
#
#        调整战士 武器-狂怒-防护
#
ModPlayerBalance.Warrior.Enable = 0
ModPlayerBalance.Warrior.Rate = 1.0
ModPlayerBalance.Warrior.Talent1 = 1.0
ModPlayerBalance.Warrior.Talent2 = 1.0
ModPlayerBalance.Warrior.Talent3 = 1.0
ModPlayerBalance.Warrior.Talent1Point = 41
ModPlayerBalance.Warrior.Talent2Point = 41
ModPlayerBalance.Warrior.Talent3Point = 41


