############################################
# 全局技能/天赋点调整伤害配置
############################################

#
#    ModPlayerBalance.Spell
#        描述: 逗号分隔的 SpellId:Rate 配置（例如 "2431:0.95, 28913:1.06"）
#              拥有即有效,无需施放此技能或天赋点技能,就可获得伤害加成。主要用于明显影响dps的技能或天赋点,对伤害微调
#        默认:         空字符串（无特殊技能倍率）
#
ModPlayerBalance.Spell = ""

#
#    ModPlayerBalance.Equip
#        描述: 逗号分隔的 EquipId:Rate 配置（例如 "32837:1.05, 32838:1.06, 34334:1.07"）
#              装备后生效,可获得伤害加成。主要用于特殊装备
#        默认:         空字符串（无特殊装备倍率）
#
ModPlayerBalance.Equip = ""